flowchart TB
    subgraph Traditional["Traditional Architecture Practice"]
        T1["Static Documents"]:::kv-muted
        T2["Manual Processes"]:::kv-muted
        T3["Tribal Knowledge"]:::kv-muted
    end
    subgraph AaC["Architecture as Code"]
        A1["Version-controlled\nArtefacts"]:::kv-primary
